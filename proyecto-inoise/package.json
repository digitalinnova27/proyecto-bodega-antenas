{
  "name": "rfid-dashboard-final",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --config frontend/vite.config.js",
    "build": "vite build --config frontend/vite.config.js",
    "preview": "vite preview --config frontend/vite.config.js",
    "electron": "electron .",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron .",
    "start": "npm run electron:dev",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win --dir",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.7",
    "@mui/material": "^5.14.7",
    "better-sqlite3": "^12.11.1",
    "jspdf": "^2.5.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.1",
    "recharts": "^2.15.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.0",
    "electron": "^40.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.inoise.bodega",
    "productName": "iNOISE Control Bodega",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "server/**/*",
      "!**/node_modules/**",
      "node_modules/better-sqlite3/**/*",
      "server/node_modules/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icono.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/assets/icono.png",
      "installerHeaderIcon": "electron/assets/icono.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
